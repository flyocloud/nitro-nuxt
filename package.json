{
  "name": "@flyo/nitro-nuxt",
  "version": "2.0.0",
  "description": "Flyo Nitro Nuxt Module",
  "repository": "git@github.com:flyocloud/nitro-nuxt.git",
  "author": "Basil Suter <git@nadar.io>",
  "license": "MIT",
  "type": "module",
  "module": "./dist/module.mjs",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "npm run test && npm run build",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "playground:dev": "npm --prefix playground run dev",
    "playground:build": "npm --prefix playground run build"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@nuxt/module-builder": "^1.0.2",
    "@types/node": "^25.4.0",
    "nuxt": "^4.3.1",
    "semantic-release": "^25.0.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@flyo/nitro-vue3": "^2.2.0",
    "@nuxt/kit": "^4.3.1",
    "defu": "^6.1.4"
  }
}
